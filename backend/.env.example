# Production (e.g. Railway): point DATABASE_URL at Postgres. `pnpm run start:prod` runs `prisma migrate deploy` before starting the API so tables stay in sync.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sqspeptides_store?schema=public"
PORT=3001
HOST=0.0.0.0
FRONTEND_ORIGIN=http://localhost:3000
# Optional CSV list for production CORS (preferred over single origin):
# FRONTEND_ORIGINS=https://www.sqspeptides.com,https://sq-speptides-frontend-inky.vercel.app,http://localhost:3000

# Same value as JWT_SECRET in the Next.js app root .env
JWT_SECRET=dev-only-change-in-production
JWT_EXPIRES_IN=7d

# Seeded admin (pnpm prisma db seed)
ADMIN_EMAIL=admin@sqspeptides.local
ADMIN_PASSWORD=ChangeMeAdmin123!

# PayRam — required on Nest only (not in Next .env). Same key verifies webhooks (payram verifyApiKey) and API calls.
# Dashboard URL is for humans; PAYRAM_BASE_URL is usually the API host origin (code also tries /project/all/... paths).
PAYRAM_BASE_URL=http://127.0.0.1
PAYRAM_API_URL=http://127.0.0.1
PAYRAM_API_KEY=replace-with-payram-project-api-key
# Optional override if payment POST is not at {origin}/api/v1/payment
PAYRAM_PAYMENT_ENDPOINT=
# In PayRam UI set webhook to your live Next URL, e.g. https://www.sqspeptides.com/api/payram/webhook (Next BFF forwards to Nest /api/payram/webhook).
# Deposit/sweeper/cold/master wallets are configured in the PayRam dashboard, not here.
# For production, set FRONTEND_ORIGINS to your storefront domains.
