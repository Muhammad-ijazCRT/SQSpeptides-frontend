# Production (e.g. Railway): point DATABASE_URL at Postgres. `pnpm run start:prod` runs `prisma migrate deploy` before starting the API so tables stay in sync.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sqspeptides_store?schema=public"
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Same value as JWT_SECRET in the Next.js app root .env
JWT_SECRET=dev-only-change-in-production
JWT_EXPIRES_IN=7d

# Seeded admin (pnpm prisma db seed)
ADMIN_EMAIL=admin@sqspeptides.local
ADMIN_PASSWORD=ChangeMeAdmin123!
