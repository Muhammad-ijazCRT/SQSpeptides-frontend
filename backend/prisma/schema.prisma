generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id                         String   @id
  affiliateCommissionPercent Decimal  @default(10) @db.Decimal(5, 2)
  nowpaymentsApiKey          String?  @db.Text
  nowpaymentsPublicKey       String?  @db.Text
  nowpaymentsSandbox         Boolean  @default(true)
  /** Shown on checkout for Zelle (email address). */
  zelleEmail                 String?  @db.Text
  /** Shown on checkout for Zelle (phone in +1… format recommended). */
  zellePhone                 String?  @db.Text
  /** SMTP host for transactional mail (payment confirmations, etc.). */
  mailHost                   String?  @db.Text
  mailPort                   Int?
  mailSecure                 Boolean  @default(false)
  mailUser                   String?  @db.Text
  mailPassword               String?  @db.Text
  mailFrom                   String?  @db.Text
  updatedAt                  DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id                String                  @id @default(cuid())
  email             String                  @unique
  passwordHash      String
  name              String
  affiliateCode     String?                 @unique
  affiliateBalance  Decimal                 @default(0) @db.Decimal(12, 2)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  orders            Order[]
  addresses         CustomerAddress[]
  wishlistItems     WishlistItem[]
  paymentMethods    SavedPaymentMethod[]
  affiliateEarnings AffiliateEarning[]
  payoutRequests    AffiliatePayoutRequest[]
  referredOrders    Order[]                 @relation("AffiliateReferrals")
}

model Product {
  id            String          @id @default(cuid())
  slug          String          @unique
  name          String
  description   String?
  price         Decimal         @db.Decimal(10, 2)
  imageUrl      String?
  rating        Float           @default(5)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  percentOff Decimal  @db.Decimal(5, 2)
  active     Boolean  @default(true)
  maxUses    Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]

  @@index([active])
}

model Order {
  id                     String            @id @default(cuid())
  customerId             String?
  customer               Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  email                  String
  fullName               String
  addressLine1           String
  city                   String
  postalCode             String
  country                String
  researchUseAttestation String
  total                  Decimal           @db.Decimal(12, 2)
  status                 String            @default("pending")
  affiliateReferrerId    String?
  affiliateReferrer      Customer?         @relation("AffiliateReferrals", fields: [affiliateReferrerId], references: [id], onDelete: SetNull)
  storeCreditUsed        Decimal           @default(0) @db.Decimal(12, 2)
  couponId               String?
  coupon                 Coupon?           @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCodeSnapshot     String?
  couponDiscountAmount   Decimal           @default(0) @db.Decimal(12, 2)
  paymentProvider        String?
  paymentCompletion      String            @default("paid")
  nowpaymentsInvoiceId   String?
  zelleTransactionId     String?
  /** Public URL path e.g. /uploads/zelle/…. */
  zelleProofUrl          String?           @db.Text
  zelleSubmittedAt       DateTime?
  zelleRejectionNote     String?           @db.Text
  createdAt              DateTime          @default(now())
  items                  OrderItem[]
  affiliateEarning       AffiliateEarning?
  payments               OrderPayment[]

  @@index([customerId])
  @@index([email])
  @@index([affiliateReferrerId])
  @@index([couponId])
}

model AffiliateEarning {
  id                String   @id @default(cuid())
  affiliateId       String
  affiliate         Customer @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  orderId           String   @unique
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderSubtotal     Decimal  @db.Decimal(12, 2)
  commissionPercent Decimal  @db.Decimal(5, 2)
  amount            Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())

  @@index([affiliateId])
}

model AffiliatePayoutRequest {
  id               String   @id @default(cuid())
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount           Decimal  @db.Decimal(12, 2)
  status           String   @default("pending")
  note             String?
  adminNote        String?
  cryptoNetwork    String?
  cryptoAddress    String?
  rejectionReason  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String
  fullName   String
  line1      String
  city       String
  postalCode String
  country    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
}

model SavedPaymentMethod {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String
  brand      String
  last4      String
  expMonth   Int
  expYear    Int
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
}

model OrderPayment {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider   String
  externalId String?
  amountUsd  Decimal  @db.Decimal(12, 2)
  status     String
  rawPayload Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderId])
}

/** Admin-issued payment link: NOWPayments, Zelle instructions, or external URL. */
model PaymentInvoice {
  id                        String    @id @default(cuid())
  /** Opaque token used in public `/pay/:token` URLs. */
  publicToken               String    @unique
  /** `nowpayments` | `zelle` | `external` */
  gatewayType               String
  /** Display name shown to customer (e.g. NOWPayments, Zelle). */
  gatewayLabel              String
  amount                    Decimal   @db.Decimal(12, 2)
  currency                  String    @default("usd")
  description               String?
  customerEmail             String
  customerName              String?
  checkoutUrl               String?   @db.Text
  nowpaymentsInvoiceId      String?
  zelleTransactionId        String?
  /** Public URL path e.g. /uploads/zelle/…. */
  zelleProofUrl             String?   @db.Text
  zelleSubmittedAt          DateTime?
  /** `pending` | `paid` | `cancelled` */
  status                    String    @default("pending")
  paidAt                    DateTime?
  paymentDetails            Json?
  confirmationEmailSentAt   DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([status])
  @@index([paidAt])
  @@index([createdAt])
}
